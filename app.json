{
  "expo": {
    "name": "tempered-strength-app",
    "slug": "tempered-strength-app",
    "version": "2.3.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "temperedstrengthapp",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kieranvenison.temperedstrengthapp",
      "entitlements": {
        "com.apple.developer.ubiquity-kvstore-identifier": "$(TeamIdentifierPrefix)$(CFBundleIdentifier)"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "usesIcloudStorage": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#121212"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "753c3e7a-158d-41ec-b35c-772015ccbaa9"
      }
    }
  }
}
