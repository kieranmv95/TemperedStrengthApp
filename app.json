{
  "expo": {
    "name": "tempered-strength-app",
    "slug": "tempered-strength-app",
    "version": "2.9.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "temperedstrengthapp",
    "userInterfaceStyle": "dark",
    "androidNavigationBar": {
      "backgroundColor": "#121212",
      "barStyle": "light-content",
      "enforceContrast": false
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kieranvenison.temperedstrengthapp",
      "entitlements": {
        "com.apple.developer.ubiquity-kvstore-identifier": "$(TeamIdentifierPrefix)$(CFBundleIdentifier)"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "usesIcloudStorage": true
    },
    "android": {
      "package": "com.kieranvenison.temperedstrengthapp",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android_icon.png",
        "backgroundColor": "#121212"
      },
      "permissions": ["android.permission.POST_NOTIFICATIONS"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Tempered Strength to use your location to show nearby gyms, clubs, and coaches."
        }
      ],
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/dark-splash-icon.png",
            "backgroundColor": "#121212"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-localization",
      "expo-video",
      "expo-web-browser",
      [
        "expo-navigation-bar",
        {
          "backgroundColor": "#121212",
          "barStyle": "light",
          "enforceContrast": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "753c3e7a-158d-41ec-b35c-772015ccbaa9"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/753c3e7a-158d-41ec-b35c-772015ccbaa9"
    }
  }
}
