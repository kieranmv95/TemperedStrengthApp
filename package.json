{
  "name": "tempered-strength-app",
  "main": "expo-router/entry",
  "version": "2.10.0",
  "scripts": {
    "start": "expo start",
    "start-clean": "expo start -c",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:ios:production": "EXPO_NO_CAPABILITY_SYNC=1 eas build --platform ios --profile production",
    "build:android:production": "eas build --platform android --profile production",
    "format": "prettier --write .",
